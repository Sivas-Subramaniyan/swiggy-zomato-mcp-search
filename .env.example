# ─── Gemini LLM ───────────────────────────────────────────────
# Your Google Gemini API key — get one free at https://aistudio.google.com
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini model to use
# Recommended: gemini-2.5-flash  (fast, cheap, great for tool use)
# Options:     gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
GEMINI_MODEL="gemini-2.5-flash"

# Sampling temperature — lower = more deterministic (default: 0.1)
GEMINI_TEMPERATURE="0.1"

# Max output tokens per LLM call (default: 4096)
GEMINI_MAX_TOKENS="4096"

# ─── MCP Server URLs ──────────────────────────────────────────
SWIGGY_MCP_URL="https://mcp.swiggy.com/food"
ZOMATO_MCP_URL="https://mcp-server.zomato.com/mcp"

# ─── MLflow Tracing (optional) ────────────────────────────────
# Start MLflow separately with: mlflow ui --port 5000
MLFLOW_TRACKING_URI="http://127.0.0.1:5000"
